# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local NUNCA deve ser commitado no git (já está no .gitignore).

# Supabase — Settings > Data API / Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Cloudflare R2 — bucket "products"
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=products
NEXT_PUBLIC_R2_PUBLIC_URL=

# Google Apps Script — webhook da planilha de pedidos
GOOGLE_SHEETS_WEBHOOK_URL=
